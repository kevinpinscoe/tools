#!/usr/bin/env python3
"""gitcf — pick untracked/modified files via TUI, commit each, then push."""

import os
import subprocess
import sys
from pathlib import Path
import termios

try:
    import readline  # noqa: F401  — enables proper backspace/editing in input()
except ImportError:
    pass

try:
    import urwid
except ImportError:
    _venv = Path.home() / ".local" / "share" / "gitcf-venv"
    _venv_python = _venv / "bin" / "python3"
    if not _venv_python.exists():
        print("Setting up gitcf environment (one-time)...", flush=True)
        subprocess.run([sys.executable, "-m", "venv", str(_venv)], check=True)
        subprocess.run([str(_venv_python), "-m", "pip", "install", "urwid"], check=True)
    os.execv(str(_venv_python), [str(_venv_python)] + sys.argv)

USAGE = """\
Usage: gitcf [-h]

Pick untracked and modified files in the current git repo via a TUI,
commit each selected file with an auto-generated message ("Added <name>"
or "Modified <name>"), then push to origin.

Options:
  -h, --help    Show this help message
"""

PALETTE = [
    ("header",   "white,bold",   "dark blue"),
    ("footer",   "light gray",   "dark gray"),
    ("item",     "default",      "default"),
    ("focused",  "black",        "light cyan"),
    ("divider",  "dark gray",    "default"),
]


class EnterPassthroughCheckBox(urwid.CheckBox):
    """CheckBox that lets Enter bubble up instead of consuming it."""
    def keypress(self, size, key):
        if key == "enter":
            return key
        return super().keypress(size, key)


def fail(msg: str) -> None:
    print(f"ERROR: {msg}", file=sys.stderr)
    sys.exit(1)


def repo_root() -> Path:
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        fail("not inside a git repository")
    return Path(result.stdout.strip())


def list_changes(root: Path) -> list[tuple[str, str]]:
    """Return [(status_code, path)] for untracked, modified, added, renamed.

    Pure deletions are skipped — there's nothing meaningful to commit with the
    file's name as the message. Uses NUL-separated porcelain output so paths
    with spaces or unusual characters parse correctly.
    """
    result = subprocess.run(
        ["git", "-C", str(root), "status", "--porcelain", "-z"],
        capture_output=True, text=True, check=True,
    )
    parts = result.stdout.split("\0")
    entries: list[tuple[str, str]] = []
    i = 0
    while i < len(parts):
        rec = parts[i]
        if not rec:
            i += 1
            continue
        code = rec[:2]
        path = rec[3:]
        # Renames/copies: the next NUL-record is the source path; we keep the
        # destination (already in `path`) and skip the source.
        if code[0] in ("R", "C"):
            i += 2
        else:
            i += 1
        if code in (" D", "D ", "DD"):
            continue
        entries.append((code, path))
    return entries


class FileSelector:
    def __init__(self, entries: list[tuple[str, str]]) -> None:
        self._entries = entries
        self._selected: set[int] = set()
        self.result: list[int] | None = None

    def run(self) -> list[int] | None:
        body: list[urwid.Widget] = []
        path_width = max((len(p) for _, p in self._entries), default=20) + 2

        for i, (code, path) in enumerate(self._entries):
            label = f"  [{code}]  {path:<{path_width}}"
            cb = EnterPassthroughCheckBox(label, state=False)
            # urwid deprecated `user_arg`; use `user_args` instead.
            urwid.connect_signal(cb, "change", self._on_change, user_args=[i])
            body.append(urwid.AttrMap(cb, "item", "focused"))

        self._status = urwid.Text("  0 files selected", align="left")

        header = urwid.AttrMap(
            urwid.Columns([
                ("weight", 2, urwid.Text("  Select files to commit", align="left")),
                ("weight", 3, urwid.Text(
                    "Space=toggle  ↑↓=move  Enter=confirm  q=cancel",
                    align="right")),
            ]),
            "header",
        )

        footer = urwid.AttrMap(
            urwid.Pile([
                urwid.AttrMap(urwid.Divider("─"), "divider"),
                urwid.Padding(self._status, left=1, right=1),
            ]),
            "footer",
        )

        listbox = urwid.ListBox(urwid.SimpleListWalker(body))
        frame = urwid.Frame(
            urwid.LineBox(listbox, title=" Untracked & Modified Files "),
            header=header,
            footer=footer,
        )

        loop = urwid.MainLoop(frame, palette=PALETTE,
                              unhandled_input=self._handle_key)
        loop.run()
        return self.result

    def _on_change(self, idx: int, _cb: urwid.CheckBox, state: bool) -> None:
        if not isinstance(idx, int) or idx < 0 or idx >= len(self._entries):
            return
        if state:
            self._selected.add(idx)
        else:
            self._selected.discard(idx)
        n = len(self._selected)
        self._status.set_text(f"  {n} file{'s' if n != 1 else ''} selected")

    def _handle_key(self, key: str) -> None:
        if key in ("q", "Q", "esc"):
            self.result = None
            raise urwid.ExitMainLoop()
        if key == "enter":
            self.result = sorted(self._selected) or None
            raise urwid.ExitMainLoop()


def commit_message(code: str, path: str) -> str:
    name = Path(path).name
    if code.startswith("?"):
        return f"Added {name}"
    return f"Modified {name}"

def _readline_with_backspace(prompt: str) -> str:
    if not sys.stdin.isatty():
        sys.stdout.write(prompt)
        sys.stdout.flush()
        return sys.stdin.readline().rstrip("\n")

    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    new = termios.tcgetattr(fd)
    # We do our own echoing so we can keep behavior consistent across tmux /
    # terminals (Ghostty, etc.) and handle keys like Backspace/Delete.
    new[0] = new[0] & ~(termios.ICRNL | termios.IXON)  # iflag: don't map CR->NL
    new[3] = new[3] & ~(termios.ECHO | termios.ECHOCTL | termios.ICANON)  # lflag
    new[6][termios.VMIN] = 1
    new[6][termios.VTIME] = 0

    buf: list[str] = []
    sys.stdout.write(prompt)
    sys.stdout.flush()
    try:
        termios.tcsetattr(fd, termios.TCSADRAIN, new)
        while True:
            ch = sys.stdin.read(1)
            if ch in ("\n", "\r", ""):
                sys.stdout.write("\n")
                sys.stdout.flush()
                return "".join(buf)
            if ch in ("\x08", "\x7f"):  # BS / DEL
                if buf:
                    buf.pop()
                    sys.stdout.write("\b \b")
                    sys.stdout.flush()
                continue
            if ch == "\x1b":
                # Swallow common escape sequences (e.g. Delete = ESC [ 3 ~) so
                # they don't get echoed into the input buffer.
                seq = ch + sys.stdin.read(1) + sys.stdin.read(1)
                if seq[1:3] == "[3":
                    # Read trailing '~' if present.
                    tail = sys.stdin.read(1)
                    if tail != "~":
                        # Best-effort: ignore whatever it was.
                        pass
                    continue
                # For arrows/home/end etc., drain a few more bytes best-effort.
                for _ in range(4):
                    nxt = sys.stdin.read(1)
                    if not nxt or nxt.isalpha() or nxt == "~":
                        break
                continue
            if ch == "\x15":  # Ctrl-U
                while buf:
                    buf.pop()
                    sys.stdout.write("\b \b")
                sys.stdout.flush()
                continue
            if ch == "\x03":  # Ctrl-C
                raise KeyboardInterrupt
            buf.append(ch)
            sys.stdout.write(ch)
            sys.stdout.flush()
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def prompt_commit_memo() -> str | None:
    memo = _readline_with_backspace("Commit memo (optional, Enter for default): ").strip()
    return memo or None


def _prompt_retry_message(prev: str) -> str | None:
    retry = _readline_with_backspace(
        f"Commit failed. Enter a new message, or press Enter to retry '{prev}', or 'q' to abort: "
    ).strip()
    if retry.lower() == "q":
        return None
    return retry or prev


def main() -> None:
    args = sys.argv[1:]
    if args and args[0] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0)
    if args:
        print(f"ERROR: unknown argument: {args[0]}", file=sys.stderr)
        print(USAGE, file=sys.stderr)
        sys.exit(1)

    root = repo_root()
    entries = list_changes(root)
    if not entries:
        print("Nothing to commit: working tree clean.")
        sys.exit(0)

    picked = FileSelector(entries).run()
    if not picked:
        print("No files selected, aborting.")
        sys.exit(1)

    memo_override = prompt_commit_memo()

    committed: list[tuple[str, Path]] = []
    for i in picked:
        code, path = entries[i]
        msg = memo_override or commit_message(code, path)
        subprocess.run(["git", "-C", str(root), "add", "--", path], check=True)
        while True:
            try:
                subprocess.run(["git", "-C", str(root), "commit", "-m", msg], check=True)
                break
            except subprocess.CalledProcessError as e:
                # Common causes: commit-msg/pre-commit hooks (e.g., spellcheck).
                # Allow the user to fix the message without crashing.
                next_msg = _prompt_retry_message(msg)
                if next_msg is None:
                    print("Aborting.", file=sys.stderr)
                    sys.exit(e.returncode or 1)
                msg = next_msg
        print(f"Committed: {msg}")
        committed.append((msg, root / path))

    print("\nPushing to origin...")
    subprocess.run(["git", "-C", str(root), "push", "origin", "HEAD"], check=True)

    print(f"\nCommitted and pushed {len(committed)} "
          f"file{'s' if len(committed) != 1 else ''}:")
    msg_width = max(len(m) for m, _ in committed)
    for msg, abs_path in committed:
        print(f"  {msg:<{msg_width}}  {abs_path}")


if __name__ == "__main__":
    main()
