#!/usr/bin/env bash
set -euo pipefail

# myclaude — launch `claude` inside a named `screen` session with logging.
#
# Session name: claude-<CWD-relative-to-$HOME with / replaced by ->
#   $HOME              -> claude-home
#   $HOME/tools        -> claude-tools
#   $HOME/Projects/foo -> claude-Projects-foo
#
# Log file: <LOG_ROOT>/YYYY/MM/<session>-YYYY-MM-DD-HH-MM.log
# where LOG_ROOT is read from ~/.environment/claude-diary-log-path.txt.
#
# After the session exits, a cleaned text sibling is written next to the raw log:
#   <session>-YYYY-MM-DD-HH-MM.txt
# The cleaner drops alt-screen frame redraws (claude's TUI) and ANSI escapes so
# the result is grep- and diary-friendly without needing screen replay.

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "myclaude: required command '$1' not found in PATH" >&2
        exit 1
    }
}

# clean_log RAW_LOG
# Writes a cleaned <basename>.txt next to RAW_LOG. Removes alt-screen frame
# blocks (CSI ?1049h…?1049l, ?1047, ?47), strips remaining ANSI escapes, folds
# backspaces and carriage-return overwrites, and squeezes blank-line runs.
clean_log() {
    local raw="$1"
    if [[ ! -f "$raw" ]]; then
        echo "myclaude: clean: log file not found: $raw" >&2
        return 1
    fi
    if [[ ! -s "$raw" ]]; then
        echo "myclaude: clean: log file is empty: $raw" >&2
        return 0
    fi

    local clean
    if [[ "$raw" == *.log ]]; then
        clean="${raw%.log}.txt"
    else
        clean="$raw.txt"
    fi

    local stripper=""
    if command -v ansifilter >/dev/null 2>&1; then
        stripper=ansifilter
    elif command -v ansi2txt >/dev/null 2>&1; then
        stripper=ansi2txt
    fi
    if [[ -z "$stripper" ]]; then
        echo "myclaude: clean: neither ansifilter nor ansi2txt found; skipping .txt." >&2
        echo "  install one of:" >&2
        echo "    macOS:        brew install ansifilter" >&2
        echo "    Debian/Ubuntu: sudo apt install ansifilter   (or colorized-logs)" >&2
        echo "    Fedora:        sudo dnf install ansifilter   (or colorized-logs)" >&2
        return 0
    fi

    require_cmd perl
    require_cmd col
    require_cmd tr
    require_cmd cat

    # 1. Drop matched alt-screen toggle pairs (1049, 1047, 47).
    # 2. Drop unmatched alt-screen-enter through EOF (claude crashed mid-session).
    LC_ALL=C perl -0777 -pe '
        s/\x1b\[\?(?:1049|1047|47)h.*?\x1b\[\?(?:1049|1047|47)l//gs;
        s/\x1b\[\?(?:1049|1047|47)h.*\z//s;
    ' "$raw" \
        | "$stripper" \
        | LC_ALL=C col -b \
        | LC_ALL=C tr -d '\r' \
        | LC_ALL=C cat -s \
        > "$clean"

    if [[ -s "$clean" ]]; then
        echo "myclaude: cleaned log -> $clean"
    else
        rm -f "$clean"
        echo "myclaude: clean: cleaned output empty (no normal-screen content); kept raw only."
    fi
}

# Manual cleanup mode: `myclaude --clean <log-file>`. Useful after detaching
# from a session — rerun once the session is truly gone.
if [[ "${1:-}" == "--clean" ]]; then
    if [[ -z "${2:-}" ]]; then
        echo "myclaude: --clean requires a log file path" >&2
        echo "usage: myclaude --clean <log-file>" >&2
        exit 2
    fi
    clean_log "$2"
    exit $?
fi

require_cmd screen
require_cmd claude
require_cmd date
require_cmd mkdir

# `screen -Logfile` requires screen >= 4.06.
MIN_SCREEN_MAJOR=4
MIN_SCREEN_MINOR=6
screen_ver_line="$(screen -version 2>&1 | head -n 1)"
screen_ver="$(awk '{print $3}' <<< "$screen_ver_line")"
if [[ ! "$screen_ver" =~ ^([0-9]+)\.([0-9]+) ]]; then
    echo "myclaude: unable to parse screen version from: $screen_ver_line" >&2
    echo "  which screen: $(command -v screen)" >&2
    exit 1
fi
screen_major="$((10#${BASH_REMATCH[1]}))"
screen_minor="$((10#${BASH_REMATCH[2]}))"
if (( screen_major < MIN_SCREEN_MAJOR || (screen_major == MIN_SCREEN_MAJOR && screen_minor < MIN_SCREEN_MINOR) )); then
    echo "myclaude: screen $screen_ver is too old; need >= ${MIN_SCREEN_MAJOR}.$(printf '%02d' "$MIN_SCREEN_MINOR") for -Logfile support." >&2
    echo "  which screen: $(command -v screen)" >&2
    echo "  on macOS:  brew install screen  (and ensure /opt/homebrew/bin is ahead of /usr/bin on PATH)" >&2
    exit 1
fi

CONFIG_FILE="$HOME/.environment/claude-diary-log-path.txt"
if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "myclaude: config file not found: $CONFIG_FILE" >&2
    echo "  create it with the log root directory as its single line of content." >&2
    exit 1
fi

LOG_ROOT="$(sed -e 's/[[:space:]]*$//' -e '/^[[:space:]]*$/d' "$CONFIG_FILE" | head -n 1)"
if [[ -z "$LOG_ROOT" ]]; then
    echo "myclaude: config file is empty: $CONFIG_FILE" >&2
    exit 1
fi
LOG_ROOT="${LOG_ROOT/#\~/$HOME}"

CWD="$PWD"
if [[ "$CWD" == "$HOME" ]]; then
    REL="home"
elif [[ "$CWD" == "$HOME"/* ]]; then
    REL="${CWD#$HOME/}"
    REL="${REL//\//-}"
else
    echo "myclaude: current directory ($CWD) is not under \$HOME ($HOME)" >&2
    exit 1
fi

SESSION="claude-$REL"

if screen -ls 2>/dev/null | awk '{print $1}' | grep -qE "\.${SESSION}\$"; then
    echo "myclaude: a screen session named '$SESSION' already exists." >&2
    echo "  attach with: screen -r $SESSION" >&2
    echo "  list all:   screen -ls" >&2
    exit 1
fi

NOW_Y="$(date +%Y)"
NOW_M="$(date +%m)"
NOW_STAMP="$(date +%Y-%m-%d-%H-%M)"

LOG_DIR="$LOG_ROOT/$NOW_Y/$NOW_M"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/${SESSION}-${NOW_STAMP}.log"

set +e
screen -S "$SESSION" -L -Logfile "$LOG_FILE" bash -c 'date && claude'
screen_rc=$?
set -e

[[ -f "$LOG_FILE" ]] && echo "myclaude: raw log -> $LOG_FILE"

# After screen returns: was it a detach (daemon still alive) or a true exit?
# On detach the log is still being written by the running daemon, so cleaning
# now would race; print a hint instead and let the user run --clean later.
if screen -ls 2>/dev/null | awk '{print $1}' | grep -qE "\.${SESSION}\$"; then
    echo "myclaude: detached from $SESSION (session still running, log still recording)"
    echo "  reattach: screen -r $SESSION"
    echo "  after exit, clean with: myclaude --clean '$LOG_FILE'"
    exit "$screen_rc"
fi

clean_log "$LOG_FILE"
exit "$screen_rc"
