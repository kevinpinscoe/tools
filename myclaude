#!/usr/bin/env bash
set -euo pipefail

# myclaude — launch `claude` inside a named `abduco` session with `script` logging.
#
# Session name: claude-<CWD-relative-to-$HOME with / replaced by ->
#   $HOME              -> claude-home
#   $HOME/tools        -> claude-tools
#   $HOME/Projects/foo -> claude-Projects-foo
#
# Log file: <LOG_ROOT>/CLAUDE/_<REL>/YYYY-MM-DD-HH-MM.log
# where LOG_ROOT is read from one of:
#   ~/.environment/claude-diary-log-path-for-mac.txt    (Darwin/macOS)
#   ~/.environment/claude-diary-log-path-for-fedora.txt (x86_64 Linux)
#   ~/.environment/claude-diary-log-path-for-rpi.txt    (arm64/aarch64 Linux)
# and <REL> is the cwd relative to $HOME, with `/` replaced by `-`
# (so `~/.environment` -> `_.environment`, `~/Projects/foo` -> `_Projects-foo`,
# and `$HOME` itself -> `_home`). The leading `_` is for visibility in listings.
#
# Inside the abduco session: `script` begins logging immediately, then runs
# `date && exec claude`.
#
# After the session exits, a cleaned text sibling is written next to the raw log:
#   YYYY-MM-DD-HH-MM.txt
# The cleaner drops alt-screen frame redraws (claude's TUI) and ANSI escapes so
# the result is grep- and diary-friendly without needing session replay.
#
# Detach from session: Ctrl+\  (abduco default)
# Reattach:           abduco -a <session-name>
# List sessions:      abduco

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "myclaude: required command '$1' not found in PATH" >&2
        exit 1
    }
}

# clean_log RAW_LOG
# Writes a cleaned <basename>.txt next to RAW_LOG. Removes alt-screen frame
# blocks (CSI ?1049h…?1049l, ?1047, ?47), strips remaining ANSI escapes, folds
# backspaces and carriage-return overwrites, and squeezes blank-line runs.
clean_log() {
    local raw="$1"
    if [[ ! -f "$raw" ]]; then
        echo "myclaude: clean: log file not found: $raw" >&2
        return 1
    fi
    if [[ ! -s "$raw" ]]; then
        echo "myclaude: clean: log file is empty: $raw" >&2
        return 0
    fi

    local clean
    if [[ "$raw" == *.log ]]; then
        clean="${raw%.log}.txt"
    else
        clean="$raw.txt"
    fi

    local stripper=""
    if command -v ansifilter >/dev/null 2>&1; then
        stripper=ansifilter
    elif command -v ansi2txt >/dev/null 2>&1; then
        stripper=ansi2txt
    fi
    if [[ -z "$stripper" ]]; then
        echo "myclaude: clean: neither ansifilter nor ansi2txt found; skipping .txt." >&2
        echo "  install one of:" >&2
        echo "    macOS:        brew install ansifilter" >&2
        echo "    Debian/Ubuntu: sudo apt install ansifilter   (or colorized-logs)" >&2
        echo "    Fedora:        sudo dnf install ansifilter   (or colorized-logs)" >&2
        return 0
    fi

    require_cmd perl
    require_cmd col
    require_cmd tr
    require_cmd cat

    # 1. Drop matched alt-screen toggle pairs (1049, 1047, 47).
    # 2. Drop unmatched alt-screen-enter through EOF (claude crashed mid-session).
    LC_ALL=C perl -0777 -pe '
        s/\x1b\[\?(?:1049|1047|47)h.*?\x1b\[\?(?:1049|1047|47)l//gs;
        s/\x1b\[\?(?:1049|1047|47)h.*\z//s;
    ' "$raw" \
        | "$stripper" \
        | LC_ALL=C col -b \
        | LC_ALL=C tr -d '\r' \
        | LC_ALL=C cat -s \
        > "$clean"

    if [[ -s "$clean" ]]; then
        echo "myclaude: cleaned log -> $clean"
    else
        rm -f "$clean"
        echo "myclaude: clean: cleaned output empty (no normal-screen content); kept raw only."
    fi
}

# Manual cleanup mode: `myclaude --clean <log-file>`. Useful after detaching
# from a session — rerun once the session is truly gone.
if [[ "${1:-}" == "--clean" ]]; then
    if [[ -z "${2:-}" ]]; then
        echo "myclaude: --clean requires a log file path" >&2
        echo "usage: myclaude --clean <log-file>" >&2
        exit 2
    fi
    clean_log "$2"
    exit $?
fi

require_cmd abduco
require_cmd script
require_cmd claude
require_cmd date
require_cmd mkdir

# Claude Code 2.1.132 introduced CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN, which
# myclaude relies on to keep the conversation in the terminal's native
# scrollback so `script` captures cleanly.
MIN_CLAUDE_VERSION="2.1.132"

parse_claude_version() {
    local raw ver
    raw="$(claude --version 2>/dev/null | head -n 1)"
    ver="$(awk '{print $1}' <<< "$raw")"
    if [[ ! "$ver" =~ ^[0-9]+\.[0-9]+\.[0-9]+ ]]; then
        echo "myclaude: unable to parse claude version from: $raw" >&2
        echo "  which claude: $(command -v claude)" >&2
        exit 1
    fi
    echo "$ver"
}

version_ge() {
    local actual="$1" required="$2"
    [[ "$(printf '%s\n%s\n' "$actual" "$required" | sort -V | head -n 1)" == "$required" ]]
}

claude_ver="$(parse_claude_version)"
if ! version_ge "$claude_ver" "$MIN_CLAUDE_VERSION"; then
    echo "myclaude: claude $claude_ver is older than required $MIN_CLAUDE_VERSION." >&2
    echo "  CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN=1 (used by myclaude for clean log capture)" >&2
    echo "  needs Claude Code >= $MIN_CLAUDE_VERSION." >&2
    echo "  see https://code.claude.com/docs/en/changelog#2-1-132" >&2
    echo "myclaude: running 'claude update' to upgrade..." >&2
    if ! claude update; then
        echo "myclaude: 'claude update' failed; upgrade manually and retry." >&2
        echo "  install docs: https://docs.claude.com/en/docs/claude-code/installation" >&2
        exit 1
    fi
    claude_ver="$(parse_claude_version)"
    if ! version_ge "$claude_ver" "$MIN_CLAUDE_VERSION"; then
        echo "myclaude: still on claude $claude_ver after update; required >= $MIN_CLAUDE_VERSION." >&2
        echo "  consider reinstalling claude: https://docs.claude.com/en/docs/claude-code/installation" >&2
        exit 1
    fi
    echo "myclaude: upgraded to claude $claude_ver" >&2
fi

OS_UNAME="$(uname -s 2>/dev/null || true)"
ARCH_UNAME="$(uname -m 2>/dev/null || true)"

case "$OS_UNAME" in
    Darwin)
        CONFIG_FILE="$HOME/.environment/claude-diary-log-path-for-mac.txt"
        ;;
    *)
        case "$ARCH_UNAME" in
            x86_64)
                CONFIG_FILE="$HOME/.environment/claude-diary-log-path-for-fedora.txt"
                ;;
            arm64|aarch64)
                CONFIG_FILE="$HOME/.environment/claude-diary-log-path-for-rpi.txt"
                ;;
            *)
                echo "myclaude: unsupported host architecture/platform." >&2
                echo "  uname -s: $OS_UNAME" >&2
                echo "  uname -m: $ARCH_UNAME" >&2
                echo "  expected one of: Darwin, x86_64, arm64" >&2
                exit 1
                ;;
        esac
        ;;
esac

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "myclaude: config file not found: $CONFIG_FILE" >&2
    echo "  create it with the log root directory as its single line of content." >&2
    exit 1
fi

LOG_ROOT="$(sed -e 's/[[:space:]]*$//' -e '/^[[:space:]]*$/d' "$CONFIG_FILE" | head -n 1)"
if [[ -z "$LOG_ROOT" ]]; then
    echo "myclaude: config file is empty: $CONFIG_FILE" >&2
    exit 1
fi
LOG_ROOT="${LOG_ROOT/#\~/$HOME}"

CWD="$PWD"
if [[ "$CWD" == "$HOME" ]]; then
    REL="home"
elif [[ "$CWD" == "$HOME"/* ]]; then
    REL="${CWD#$HOME/}"
    REL="${REL//\//-}"
else
    echo "myclaude: current directory ($CWD) is not under \$HOME ($HOME)" >&2
    exit 1
fi

SESSION="claude-$REL"

# abduco session collision check
if abduco 2>/dev/null | awk 'NR>1 && NF>0 {print $NF}' | grep -qxF "$SESSION"; then
    echo "myclaude: an abduco session named '$SESSION' already exists." >&2
    echo "  attach with: abduco -a $SESSION" >&2
    echo "  list all:    abduco" >&2
    exit 1
fi

NOW_STAMP="$(date +%Y-%m-%d-%H-%M)"
LOG_DIR="$LOG_ROOT/CLAUDE/_$REL"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/${NOW_STAMP}.log"
touch "$LOG_FILE"

# Force claude to render into the terminal's native scrollback rather than the
# alternate-screen / fullscreen TUI buffer. `script` captures append-only
# output cleanly; in-place fullscreen redraws would leak through the .txt
# cleaner as fragmented characters. (Claude Code 2.1.132+)
export CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN=1

printf '%s\n' \
    '┌─────────────────┬────────────────────────────────────┬───────────────────┐' \
    '│                 │ old myclaude (now myclaude-screen) │   new myclaude    │' \
    '├─────────────────┼────────────────────────────────────┼───────────────────┤' \
    '│ Session manager │ screen                             │ abduco            │' \
    '├─────────────────┼────────────────────────────────────┼───────────────────┤' \
    '│ Detach key      │ Ctrl-A D                           │ Ctrl+\            │' \
    '├─────────────────┼────────────────────────────────────┼───────────────────┤' \
    '│ Reattach        │ screen -r SESSION                  │ abduco -a SESSION │' \
    '├─────────────────┼────────────────────────────────────┼───────────────────┤' \
    '│ List sessions   │ screen -ls                         │ abduco            │' \
    '├─────────────────┼────────────────────────────────────┼───────────────────┤' \
    '│ Logger          │ screen -L via screenrc             │ script(1)         │' \
    '└─────────────────┴────────────────────────────────────┴───────────────────┘'
echo "myclaude: starting session '$SESSION'"
echo "myclaude: log -> $LOG_FILE"
echo "myclaude: detach with Ctrl+\\"

set +e
abduco -c "$SESSION" script -a -f -q -c 'date && exec claude' "$LOG_FILE"
abduco_rc=$?
set -e

[[ -f "$LOG_FILE" ]] && echo "myclaude: raw log -> $LOG_FILE"

# Distinguish detach (session daemon still alive) from true exit.
# On detach the log is still being written; clean now would race.
if abduco 2>/dev/null | awk 'NR>1 && NF>0 {print $NF}' | grep -qxF "$SESSION"; then
    echo "myclaude: detached from '$SESSION' (session still running, log still recording)"
    echo "  reattach: abduco -a $SESSION"
    echo "  after exit, clean with: myclaude --clean '$LOG_FILE'"
    exit "$abduco_rc"
fi

clean_log "$LOG_FILE"
exit "$abduco_rc"
