#!/usr/bin/env bash
set -euo pipefail

err() { echo "restore: $*" >&2; exit 1; }

# Usage
[ $# -eq 1 ] || err "usage: restore <file>"

base="$1"

# Your current directory is treated as the original path
absdir="$(pwd -P)" || err "cannot resolve current directory"
rel="${absdir#/}"
src_dir="$HOME/.backups/$rel"
src="$src_dir/$base"

[ -d "$src_dir" ] || err "no backups directory for this path: $src_dir"
[ -e "$src" ] || err "no backup found for $base under $src_dir"

cp -a "$src" "$absdir/$base" || err "copy failed"

echo "Restored: $src -> $absdir/$base"

